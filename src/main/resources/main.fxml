<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="736.0" prefWidth="960.0"
            styleClass="root-pane"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainController">

    <!-- ═══════ HEADER ═══════ -->
    <top>
        <VBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="960.0"
              spacing="4.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="14.0" left="32.0" right="32.0" top="14.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <Label styleClass="header-badge" text="PG-03" />
                        <Label styleClass="header-title"
                               text="Tipos de Algoritmos y Listas Enlazadas (simples y dobles) en JavaFx">
                            <font><Font size="22.0" /></font>
                        </Label>
                    </children>
                </HBox>
                <Label styleClass="header-sub"
                       text="IF-3001 · Algoritmos y Estructuras de Datos">
                    <font><Font size="12.0" /></font>
                </Label>
            </children>
        </VBox>
    </top>

    <!-- ═══════ CENTER ═══════ -->
    <center>
        <TabPane fx:id="mainTabPane"
                 prefHeight="200.0" prefWidth="200.0"
                 styleClass="main-tabs"
                 tabClosingPolicy="UNAVAILABLE"
                 BorderPane.alignment="CENTER">
            <tabs>

                <!-- ════════════════════════════════════════
                     TAB · MILLER-RABIN
                ═════════════════════════════════════════ -->
                <Tab text="Miller-Rabin">
                    <content>
                        <SplitPane dividerPositions="0.58"
                                   prefHeight="636.0" prefWidth="960.0">
                            <items>

                                <!-- ── PANEL IZQUIERDO ── -->
                                <VBox spacing="12.0"
                                      style="-fx-background-color: white; -fx-padding: 20;">

                                    <!-- Título del algoritmo -->
                                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Miller-Rabin para enteros grandes. Solución con la Técnica Algoritmos Probabilistas" />

                                    <!-- Canvas / área de visualización central -->
                                    <VBox VBox.vgrow="ALWAYS"
                                          style="-fx-background-color: #F9FBFF; -fx-border-color: #E8ECF2; -fx-border-radius: 6; -fx-background-radius: 6;"
                                          alignment="CENTER"
                                          minHeight="300.0">
                                        <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
                                        <children>
                                            <Canvas fx:id="canvasMillerRabin" height="320.0" width="480.0" />
                                            <Label fx:id="lblCanvasHint"
                                                   style="-fx-text-fill: #8896A5; -fx-font-size: 13px; -fx-font-style: italic;"
                                                   text="Presione 'Miller-Rabin' para comenzar" />
                                        </children>
                                    </VBox>

                                    <!-- Tabla de resultados -->
                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Lista de Big Integers que pasaron el Test de Primalidad" />

                                    <TableView fx:id="tableMillerRabin"
                                               prefHeight="180.0"
                                               style="-fx-background-color: white; -fx-border-color: #E8ECF2; -fx-font-size: 12px;">
                                        <columns>
                                            <TableColumn fx:id="colBigNumber"
                                                         prefWidth="260.0"
                                                         text="Big number" />
                                            <TableColumn fx:id="colEsPrimo"
                                                         prefWidth="220.0"
                                                         text="Es Probablemente Primo ?" />
                                        </columns>
                                        <placeholder>
                                            <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;"
                                                   text="Tabla sin contenido" />
                                        </placeholder>
                                    </TableView>

                                </VBox>

                                <!-- ── PANEL DERECHO ── -->
                                <VBox prefWidth="390.0" spacing="12.0"
                                      style="-fx-background-color: #F4F6FA; -fx-padding: 18;">

                                    <!-- Parámetros -->
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Parámetros" />

                                    <!-- Spinner de rondas / iteraciones -->
                                    <Spinner fx:id="spinnerRounds"
                                             prefWidth="120.0" prefHeight="30.0"
                                             style="-fx-font-size: 13px;" />

                                    <!-- Big Integer generado -->
                                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                                        <children>
                                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                                   text="Big Integer:" />
                                            <Label fx:id="lblBigInteger"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #1A8C7B; -fx-font-weight: bold;"
                                                   text="--" />
                                        </children>
                                    </HBox>

                                    <!-- Botones Generar / Limpiar campo -->
                                    <HBox spacing="10.0">
                                        <children>
                                            <Button fx:id="btnGenerar"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-secondary"
                                                    text="Generar aleatorio"
                                                    HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnLimpiarCampo"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-ghost"
                                                    text="Limpiar campo"
                                                    HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>

                                    <!-- Botones Miller-Rabin / Limpiar Todo -->
                                    <HBox spacing="10.0">
                                        <children>
                                            <Button fx:id="btnMillerRabin"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-primary"
                                                    text="Miller-Rabin"
                                                    HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnLimpiarTodo"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-ghost"
                                                    text="Limpiar Todo"
                                                    HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>

                                    <!-- Registro de Operaciones -->
                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Registro de Operaciones">
                                        <padding><Insets top="6.0" /></padding>
                                    </Label>

                                    <ListView fx:id="listRegistroOperaciones"
                                              styleClass="steps-list"
                                              VBox.vgrow="ALWAYS"
                                              prefHeight="200.0">
                                        <placeholder>
                                            <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;"
                                                   text="" />
                                        </placeholder>
                                    </ListView>

                                    <!-- Info box azul oscuro -->
                                    <VBox spacing="6.0"
                                          style="-fx-background-color: #1F3868; -fx-background-radius: 4; -fx-padding: 12;">
                                        <children>
                                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"
                                                   text="&quot;Test de Primalidad&quot; utilizando el algoritmo de Miller-Rabin" />
                                            <Label style="-fx-font-size: 11px; -fx-text-fill: #ADBDD4; -fx-wrap-text: true;"
                                                   text="Algoritmo probabilístico eficiente utilizado para determinar si un número entero grande es primo o compuesto. A diferencia de los métodos deterministas, este test es muy rápido, lo que lo hace fundamental en criptografía (como en RSA) para generar números primos de gran tamaño en poco tiempo." />
                                            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #ADBDD4;"
                                                   text="List de Big Integers para pruebas:" />
                                            <Label style="-fx-font-size: 10px; -fx-text-fill: #8FAFD4; -fx-wrap-text: true;"
                                                   text="1000000007, 184467440737095551557, 1000000000000000000003, 2305843009213693951" />
                                        </children>
                                    </VBox>

                                </VBox>

                            </items>
                        </SplitPane>
                    </content>
                </Tab>

                <!-- ════════════════════════════════════════
                     TAB · RANDOM SEARCH
                ═════════════════════════════════════════ -->
                <Tab text="Random Search">
                    <content>
                        <SplitPane dividerPositions="0.62"
                                   prefHeight="636.0" prefWidth="960.0">
                            <items>

                                <!-- ── PANEL IZQUIERDO ── -->
                                <VBox spacing="10.0"
                                      style="-fx-background-color: white; -fx-padding: 20;">

                                    <!-- Título del algoritmo -->
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Búsqueda aleatoria en un arreglo con un máximo de intentos permitidos" />

                                    <!-- Arreglo generado (label de texto) -->
                                    <Label fx:id="lblArrayRS"
                                           wrapText="true"
                                           style="-fx-font-size: 11px; -fx-text-fill: #4A5568; -fx-background-color: #F4F6FA; -fx-border-color: #E8ECF2; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8 12 8 12; -fx-font-family: 'Courier New';"
                                           text="[  ]  (n=0)" />

                                    <!-- Canvas / área de visualización central -->
                                    <VBox VBox.vgrow="ALWAYS"
                                          style="-fx-background-color: #F9FBFF; -fx-border-color: #E8ECF2; -fx-border-radius: 6; -fx-background-radius: 6;"
                                          alignment="CENTER"
                                          minHeight="240.0">
                                        <padding><Insets bottom="16" left="16" right="16" top="16"/></padding>
                                        <children>
                                            <!-- Resultado de búsqueda (texto central) -->
                                            <Label fx:id="lblResultadoBusquedaRS"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #4A5568; -fx-font-style: italic;"
                                                   text="" />
                                            <!-- Resultado NOT FOUND en rojo -->
                                            <Label fx:id="lblNoEncontradoRS"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #E53E3E;"
                                                   text="" />
                                            <Canvas fx:id="canvasRandomSearch" height="200.0" width="520.0" />
                                            <Label fx:id="lblCanvasHintRandomSearch"
                                                   style="-fx-text-fill: #8896A5; -fx-font-size: 13px; -fx-font-style: italic;"
                                                   text="Presione 'Random Search' para comenzar" />
                                        </children>
                                    </VBox>

                                    <!-- Tabla de resultados -->
                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Lista de elementos encontrados con el algoritmo Random Search" />

                                    <TableView fx:id="tableRandomSearch"
                                               prefHeight="160.0"
                                               style="-fx-background-color: white; -fx-border-color: #E8ECF2; -fx-font-size: 12px;">
                                        <columns>
                                            <TableColumn fx:id="colValor"
                                                         prefWidth="130.0"
                                                         text="Valor" />
                                            <TableColumn fx:id="colIndice"
                                                         prefWidth="130.0"
                                                         text="Indice" />
                                            <TableColumn fx:id="colIntentosRegistrados"
                                                         prefWidth="130.0"
                                                         text="Intentos registrados" />
                                            <TableColumn fx:id="colMaximoIntentos"
                                                         prefWidth="130.0"
                                                         text="Máximo de intentos" />
                                        </columns>
                                        <placeholder>
                                            <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;"
                                                   text="Tabla sin contenido" />
                                        </placeholder>
                                    </TableView>

                                </VBox>

                                <!-- ── PANEL DERECHO ── -->
                                <VBox prefWidth="370.0" spacing="10.0"
                                      style="-fx-background-color: #F4F6FA; -fx-padding: 18;">

                                    <!-- Parámetros -->
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Parámetros" />

                                    <!-- Slider de tamaño del arreglo -->
                                    <Slider fx:id="sliderArraySizeRS"
                                            min="0" max="100" value="20"
                                            showTickLabels="true"
                                            showTickMarks="true"
                                            majorTickUnit="25"
                                            minorTickCount="4"
                                            snapToTicks="false"
                                            style="-fx-padding: 4 0 4 0;" />

                                    <!-- Fila: Valor · Max Attempts · Generar aleatorio -->
                                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                                        <children>
                                            <!-- Valor -->
                                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                                <children>
                                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                                           text="Valor:" />
                                                    <Spinner fx:id="spinnerValueRS"
                                                             prefWidth="70.0" prefHeight="30.0"
                                                             style="-fx-font-size: 12px;" />
                                                </children>
                                            </HBox>

                                            <!-- Max Attempts -->
                                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                                <children>
                                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                                           text="Max Attempts:" />
                                                    <Spinner fx:id="spinnerMaxAttemptsRS"
                                                             prefWidth="70.0" prefHeight="30.0"
                                                             style="-fx-font-size: 12px;" />
                                                </children>
                                            </HBox>

                                            <!-- Botón Generar aleatorio -->
                                            <Button fx:id="btnGenerarAleatorioRS"
                                                    styleClass="btn-secondary"
                                                    text="Generar aleatorio"
                                                    HBox.hgrow="ALWAYS"
                                                    maxWidth="Infinity" />
                                        </children>
                                    </HBox>

                                    <!-- Botones Random Search / Limpiar -->
                                    <HBox spacing="10.0">
                                        <children>
                                            <Button fx:id="btnRandomSearch"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-primary"
                                                    text="Random Search"
                                                    HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnLimpiarRS"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-ghost"
                                                    text="Limpiar"
                                                    HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>

                                    <!-- Registro de Operaciones -->
                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Registro de Operaciones">
                                        <padding><Insets top="4.0" /></padding>
                                    </Label>

                                    <ListView fx:id="listRegistroOperacionesRS"
                                              styleClass="steps-list"
                                              VBox.vgrow="ALWAYS"
                                              prefHeight="240.0">
                                        <placeholder>
                                            <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;"
                                                   text="" />
                                        </placeholder>
                                    </ListView>

                                    <!-- Info box azul oscuro (como TextArea estilizado) -->
                                    <VBox spacing="0.0"
                                          style="-fx-background-color: #1F3868; -fx-background-radius: 4; -fx-border-color: #4A90D9; -fx-border-width: 1; -fx-border-radius: 4;">
                                        <children>
                                            <!-- Cabecera del info box -->
                                            <HBox alignment="CENTER_LEFT"
                                                  style="-fx-padding: 8 12 6 12;">
                                                <children>
                                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"
                                                           text="Búsqueda aleatoria en un arreglo" />
                                                </children>
                                            </HBox>
                                            <!-- Contenido tipo textarea -->
                                            <TextArea fx:id="txtInfoRS"
                                                      editable="false"
                                                      wrapText="true"
                                                      prefHeight="120.0"
                                                      style="-fx-control-inner-background: #1A3060; -fx-background-color: #1A3060; -fx-text-fill: #ADBDD4; -fx-font-size: 11px; -fx-font-family: 'Courier New'; -fx-border-color: transparent; -fx-background-radius: 0 0 4 4;"
                                                      text="Devuelve un arreglo de 2 elementos con el índice encontrado y el número de intentos realizados. Si el índice es -1 significa que el elemento no fue encontrado en el máximo de intentos permitidos." />
                                        </children>
                                    </VBox>

                                </VBox>

                            </items>
                        </SplitPane>
                    </content>
                </Tab>

                <!-- ════════════════════════════════════════
                     TAB · LINKED LIST
                ═════════════════════════════════════════ -->
                <Tab text="Linked List">
                    <content>
                        <SplitPane dividerPositions="0.62"
                                   prefHeight="636.0" prefWidth="960.0">
                            <items>

                                <!-- ── PANEL IZQUIERDO ── -->
                                <VBox spacing="10.0"
                                      style="-fx-background-color: white; -fx-padding: 16 20 16 20;">

                                    <!-- Título del algoritmo -->
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Lista enlazada simple: HEAD → nodos → NULL" />

                                    <!-- Canvas con scroll horizontal -->
                                    <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                                                fitToHeight="true"
                                                VBox.vgrow="ALWAYS"
                                                style="-fx-background-color: #F9FBFF; -fx-border-color: #E8ECF2; -fx-border-radius: 6; -fx-background-radius: 6;"
                                                minHeight="220.0">
                                        <content>
                                            <Canvas fx:id="canvasLinkedList" height="200.0" width="560.0" />
                                        </content>
                                    </ScrollPane>

                                    <!-- Representación textual -->
                                    <VBox spacing="2.0">
                                        <children>
                                            <Label style="-fx-font-size: 10px; -fx-text-fill: #8896A5;"
                                                   text="Representación:" />
                                            <TextArea fx:id="txtRepresentacionLL"
                                                      editable="false"
                                                      wrapText="false"
                                                      prefHeight="46.0"
                                                      style="-fx-control-inner-background: #F9FBFF; -fx-border-color: #E8ECF2; -fx-font-size: 12px; -fx-font-family: 'Courier New'; -fx-text-fill: #0D1B4B;"
                                                      text="HEAD → NULL" />
                                        </children>
                                    </VBox>

                                    <!-- Label de resultado de operación (verde) -->
                                    <Label fx:id="lblResultadoLL"
                                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1A8C7B;"
                                           text="" />

                                    <!-- Título tabla -->
                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Contenido de la Lista Enlazada Simple" />

                                    <!-- Tabla de contenido -->
                                    <TableView fx:id="tableLinkedList"
                                               VBox.vgrow="ALWAYS"
                                               prefHeight="200.0"
                                               style="-fx-background-color: white; -fx-border-color: #E8ECF2; -fx-font-size: 12px;">
                                        <columns>
                                            <TableColumn fx:id="colPosicion"
                                                         prefWidth="120.0"
                                                         text="Posición" />
                                            <TableColumn fx:id="colElemento"
                                                         prefWidth="160.0"
                                                         text="Elemento" />
                                            <TableColumn fx:id="colSeInserto"
                                                         prefWidth="200.0"
                                                         text="Se insertó al" />
                                        </columns>
                                        <placeholder>
                                            <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;"
                                                   text="Tabla sin contenido" />
                                        </placeholder>
                                    </TableView>

                                </VBox>

                                <!-- ── PANEL DERECHO ── -->
                                <VBox prefWidth="370.0" spacing="10.0"
                                      style="-fx-background-color: #F4F6FA; -fx-padding: 18;">

                                    <!-- Campo Valor en línea -->
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <children>
                                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                                   text="Valor" />
                                            <TextField fx:id="txtValueLinkedList"
                                                       prefWidth="140.0"
                                                       promptText="Ingresar valor"
                                                       style="-fx-font-size: 13px;" />
                                        </children>
                                    </HBox>

                                    <!-- Hint Enter -->
                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #8896A5;"
                                           text="(Enter = Agregar al final)" />

                                    <!-- Sección Operaciones -->
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Operaciones">
                                        <padding><Insets top="4.0" /></padding>
                                    </Label>

                                    <!-- Fila 1: Agregar inicio / Agregar final -->
                                    <HBox spacing="10.0">
                                        <children>
                                            <Button fx:id="btnAgregarInicio"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-secondary"
                                                    text="← Agregar inicio"
                                                    HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnAgregarFinal"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-primary"
                                                    text="Agregar final →"
                                                    HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>

                                    <!-- Fila 2: Buscar / Eliminar / Limpiar Todo -->
                                    <HBox spacing="10.0">
                                        <children>
                                            <Button fx:id="btnBuscar"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-secondary"
                                                    text="🔍 Buscar"
                                                    HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnEliminar"
                                                    maxWidth="Infinity"
                                                    style="-fx-font-size: 12px; -fx-text-fill: white; -fx-background-color: #27AE60; -fx-background-radius: 4; -fx-cursor: hand;"
                                                    text="🗑 Eliminar"
                                                    HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnLimpiarLinkedList"
                                                    maxWidth="Infinity"
                                                    styleClass="btn-ghost"
                                                    text="↺ Limpiar Todo"
                                                    HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>

                                    <!-- Registro de Operaciones -->
                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;"
                                           text="Registro de Operaciones">
                                        <padding><Insets top="4.0" /></padding>
                                    </Label>

                                    <ListView fx:id="listRegistroOperacionesLL"
                                              styleClass="steps-list"
                                              VBox.vgrow="ALWAYS"
                                              prefHeight="240.0">
                                        <placeholder>
                                            <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;"
                                                   text="" />
                                        </placeholder>
                                    </ListView>

                                    <!-- Info box: Estructura del Nodo (estilo dark textarea) -->
                                    <VBox spacing="0.0"
                                          style="-fx-background-color: #1F3868; -fx-background-radius: 4; -fx-border-color: #4A90D9; -fx-border-width: 1; -fx-border-radius: 4;">
                                        <children>
                                            <HBox alignment="CENTER_LEFT"
                                                  style="-fx-padding: 8 12 6 12;">
                                                <children>
                                                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"
                                                           text="Estructura del Nodo" />
                                                </children>
                                            </HBox>
